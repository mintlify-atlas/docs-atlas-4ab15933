  "keyFeatures": [
    "Complete Pokémon data for Generations 1-9 with stats, moves, abilities, and evolutions",
    "PBS (Plain Text Database) system for easy data editing without coding",
    "Comprehensive battle system with move effects, abilities, and type interactions",
    "Extensive item database including evolution stones, TMs, berries, and battle items",
    "Trainer customization system with AI levels and party configurations",
    "RPG Maker XP integration with map editing and event scripting",
    "Ruby-based scripting system for custom game mechanics",
    "Built-in tools for animations, debugging, and graphics optimization"
  ],
  "publicApiSurface": [
    "PBMove - Move data and PP management",
    "PBMoveData - Move attributes (type, power, accuracy, effects)",
    "PokemonTemp - Temporary game data storage",
    "PBS Files - pokemon.txt, moves.txt, abilities.txt, items.txt, trainers.txt, metadata.txt",
    "Editor Tools - animmaker.exe, extendtext.exe, optipng.exe",
    "Game Configuration - Game.ini, mkxp.json",
    "Script System - Data/EditorScripts/*.rb",
    "Data Compilers - PBS to binary data (.dat) conversion"
  ]
}
